<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:id="@id/infoLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:paddingTop="8.0dip"
                android:paddingBottom="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16.0dip"
                android:paddingEnd="12.0dip">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">

                    <TextView
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GNSS Information"
                        style="@style/TextAppearance.MaterialComponents.Subtitle2" />

                </LinearLayout>

                <TextView
                    android:id="@id/tvSatellitesInView"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:text="-/0" />

                <ImageView
                    android:background="?selectableItemBackgroundBorderless"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:src="@drawable/ic_baseline_satellite_alt_24"
                    android:layout_marginStart="2.0dip" />

                <ImageView
                    android:id="@id/imageNoFix"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:src="@drawable/baseline_gps_not_fixed_24" />

                <ImageView
                    android:id="@id/imageFix"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:src="@drawable/baseline_gps_fixed_24" />

            </LinearLayout>
            <View
                android:background="?colorControlNormal"
                android:layout_width="fill_parent"
                android:layout_height="1.0dip" />
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/layoutLocation"
                android:visibility="visible"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:paddingTop="8.0dip"
                        android:paddingBottom="8.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:paddingStart="16.0dip"
                        android:paddingEnd="16.0dip">
                        <LinearLayout android:orientation="horizontal"
                            android:visibility="visible"
                            android:layout_width="fill_parent"
                            android:layout_height="0.0dip"
                            android:layout_weight="1.0">
                            <TextView
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvStatusLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No Fix"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="Latitude °"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvLatitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="Longitude °"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvLongitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="Altitude (HAE in m)"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvAltitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="Mean Sea Level (m)"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvMSL"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="Geoid height (m)"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvUndulation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="PDOP"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvPDOP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="HDOP"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView android:textStyle="bold"
                                android:id="@id/tvHDOP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="VDOP"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvVDOP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="HRMS (m)"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvHRMS"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="VRMS (m)"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvVRMS"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-" style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="Fix Quality"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvFixQuality"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:text="SIGMA"
                                android:layout_weight="1.0"
                                style="@style/TextAppearance.MaterialComponents.Caption" />

                            <TextView
                                android:textStyle="bold"
                                android:id="@id/tvRMS"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1 RMS"
                                style="@style/TextAppearance.MaterialComponents.Caption" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dip">

            <LinearLayout
                android:orientation="horizontal"
                android:paddingTop="8.0dip"
                android:paddingBottom="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16.0dip"
                android:paddingEnd="16.0dip">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">

                    <TextView
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Output" style="@style/TextAppearance.MaterialComponents.Subtitle2" />
                </LinearLayout>

                <TextView
                    android:gravity="bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:text="Access to GNSS Location by"
                    android:layout_marginEnd="2.0dip"
                    style="@style/TextAppearance.MaterialComponents.Caption" />

            </LinearLayout>

            <View
                android:background="?colorControlNormal"
                android:layout_width="fill_parent"
                android:layout_height="1.0dip" />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dip">

            <br.cta.ipev.h125.gpsstatus.SkyPlotView
                android:id="@id/skyPlot"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>